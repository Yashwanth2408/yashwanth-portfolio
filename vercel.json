{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/llm", "dest": "/api/llm.js" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\.\\w+)$", "dest": "/$1" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "env": {
    "GROQ_API_KEY": "@groq_api_key",
    "GROQ_MODEL": "llama-3.3-70b-versatile"
  }
}